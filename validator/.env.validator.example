CACHEON_NETWORK=test
CACHEON_NETUID=460
CACHEON_WALLET_NAME=testnet-cacheon-1
CACHEON_WALLET_HOTKEY=testnet-cacheon-validator-1
CACHEON_POLL_INTERVAL_S=360
CACHEON_STATE_DIR=~/cacheon/state
CACHEON_DRY_RUN=0

# Docker evaluation (host paths and baseline image; digest from setup.sh after docker pull)
CACHEON_MODEL_VOLUME=/workspace/models/Qwen2.5-72B-Instruct
CACHEON_BASELINE_IMAGE=vllm/vllm-openai:latest
CACHEON_BASELINE_DIGEST=sha256:REPLACE_WITH_ACTUAL_DIGEST
# "all" passes every GPU; use "device=0,1,2,3" to restrict to specific devices
CACHEON_GPUS=all
