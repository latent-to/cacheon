CACHEON_NETWORK=test
CACHEON_NETUID=460
CACHEON_WALLET_NAME=testnet-cacheon-1
CACHEON_WALLET_HOTKEY=testnet-cacheon-validator-1
CACHEON_POLL_INTERVAL_S=360
CACHEON_STATE_DIR=~/cacheon/state
CACHEON_DRY_RUN=0
CACHEON_POLICY_CACHE_DIR=~/cacheon/state/policy-cache
CACHEON_POLICY_MAX_BYTES=1048576
# HEAD/etag revalidation timeout for hf_hub_download (not full blob download).
CACHEON_HF_ETAG_TIMEOUT_S=30.0
# Optional — only needed for private/gated HF repos
# CACHEON_HF_TOKEN=hf_...
