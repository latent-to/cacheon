# GPU pod environment variables (no bittensor, no wallet, no chain access)

# Docker evaluation
CACHEON_GPU_COUNT=4
CACHEON_MODEL_VOLUME=/workspace/models/Qwen2.5-72B-Instruct
CACHEON_BASELINE_IMAGE=vllm/vllm-openai:latest
CACHEON_BASELINE_DIGEST=sha256:REPLACE_WITH_ACTUAL_DIGEST

# Hippius S3 state sync
HIPPIUS_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
HIPPIUS_SECRET_KEY=REPLACE_WITH_SECRET_KEY
CACHEON_S3_BUCKET=cacheon-validator
CACHEON_S3_PREFIX=state