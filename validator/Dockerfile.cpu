FROM python:3.12-slim

WORKDIR /app

COPY validator/requirements-cpu.txt /app/validator/requirements-cpu.txt
COPY validator/requirements-lium-deps.txt /app/validator/requirements-lium-deps.txt
RUN pip install --no-cache-dir -r /app/validator/requirements-cpu.txt && \
    pip install --no-cache-dir --no-deps lium.io && \
    pip install --no-cache-dir -r /app/validator/requirements-lium-deps.txt

COPY validator/ /app/validator/

ENTRYPOINT ["python", "-m", "validator.cpu_validator"]
