# Bittensor chain
CACHEON_NETWORK=finney
CACHEON_NETUID=14
CACHEON_WALLET_NAME=default
CACHEON_WALLET_HOTKEY=default
CACHEON_POLL_INTERVAL_S=300
CACHEON_DRY_RUN=0

# Bittensor wallet directory (mounted read-only into container)
BITTENSOR_DIR=~/.bittensor

# Hippius S3 state sync
HIPPIUS_ACCESS_KEY=
HIPPIUS_SECRET_KEY=
CACHEON_S3_BUCKET=cacheon-validator
CACHEON_S3_PREFIX=state

# GPU orchestration (set AUTO_RENT=1 to enable automatic pod rental)
CACHEON_AUTO_RENT=0
LIUM_API_KEY=
TARGON_API_KEY=
CACHEON_MAX_HOURLY_PRICE=2000
CACHEON_GPU_TIMEOUT_MIN=120
HF_TOKEN=